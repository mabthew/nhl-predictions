generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PredictionRecord {
  id               Int      @id @default(autoincrement())
  gameId           Int
  gameDate         String
  homeAbbrev       String
  homeName         String
  homeLogo         String
  homeScore        Int
  awayAbbrev       String
  awayName         String
  awayLogo         String
  awayScore        Int
  predictedWinner  String
  actualWinner     String
  winnerCorrect    Boolean
  winnerConfidence Int
  ouLine           Float
  ouPrediction     String
  ouProjectedTotal Float?
  actualTotal      Int
  ouCorrect        Boolean
  keyFactor        String?
  propPlayer       String?
  propMarket       String?
  propLine         Float?
  propPick         String?
  homeGoalsPerGame Float?
  awayGoalsPerGame Float?
  modelVersion     String   @default("v2")
  createdAt        DateTime @default(now())

  @@unique([gameId, gameDate, modelVersion])
  @@index([gameDate])
  @@index([modelVersion])
}

model OddsCache {
  id          String   @id @default("latest")
  gameOdds    Json
  playerProps Json
  futures     Json
  updatedAt   DateTime @updatedAt
}

model AdminTotp {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  secret    String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CustomModel {
  id          String   @id @default(cuid())
  name        String
  description String
  config      Json
  createdBy   String
  chatId      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BuilderChat {
  id        String   @id @default(cuid())
  title     String
  messages  Json
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdBy])
  @@index([updatedAt])
}

model EngagementEvent {
  id        Int      @id @default(autoincrement())
  event     String
  page      String
  visitorId String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([event])
  @@index([visitorId])
}

model ApiUsageLog {
  id           Int      @id @default(autoincrement())
  provider     String
  endpoint     String
  statusCode   Int
  responseTime Int
  costEstimate Float    @default(0)
  createdBy    String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([provider])
}
