generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PredictionRecord {
  id               Int      @id @default(autoincrement())
  gameId           Int
  gameDate         String
  homeAbbrev       String
  homeName         String
  homeLogo         String
  homeScore        Int
  awayAbbrev       String
  awayName         String
  awayLogo         String
  awayScore        Int
  predictedWinner  String
  actualWinner     String
  winnerCorrect    Boolean
  winnerConfidence Int
  ouLine           Float
  ouPrediction     String
  ouProjectedTotal Float?
  actualTotal      Int
  ouCorrect        Boolean
  ouResult         String?
  keyFactor        String?
  propPlayer       String?
  propMarket       String?
  propLine         Float?
  propPick         String?
  propActualValue  Float?
  propCorrect      Boolean?
  propResult       String?
  homeGoalsPerGame Float?
  awayGoalsPerGame Float?
  modelVersion     String   @default("v2")
  createdAt        DateTime @default(now())

  @@unique([gameId, gameDate, modelVersion])
  @@index([gameDate])
  @@index([modelVersion])
}

model OddsCache {
  id          String   @id @default("latest")
  gameOdds    Json
  playerProps Json
  futures     Json
  updatedAt   DateTime @updatedAt
}

model AdminTotp {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  secret    String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CustomModel {
  id          String   @id @default(cuid())
  name        String
  description String
  config      Json
  createdBy   String
  chatId      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BuilderChat {
  id        String   @id @default(cuid())
  title     String
  messages  Json
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdBy])
  @@index([updatedAt])
}

model OddsSnapshot {
  id           Int      @id @default(autoincrement())
  snapshotDate String   @unique
  gameOdds     Json
  futures      Json
  createdAt    DateTime @default(now())

  @@index([snapshotDate])
}

model EngagementEvent {
  id         Int      @id @default(autoincrement())
  event      String
  page       String
  visitorId  String
  deviceHash String?
  userAgent  String?
  referrer   String?
  country    String?
  isAdmin    Boolean  @default(false)
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([event])
  @@index([visitorId])
  @@index([deviceHash])
  @@index([isAdmin, createdAt])
}

model ApiUsageLog {
  id           Int      @id @default(autoincrement())
  provider     String
  endpoint     String
  statusCode   Int
  responseTime Int
  costEstimate Float    @default(0)
  createdBy    String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([provider])
}

model DataFeed {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String
  provider        String
  endpoint        String
  authEnvVar      String?
  keySetupUrl     String?
  costPerCall     Float    @default(0)
  cacheDurationS  Int      @default(86400)
  factorKey       String   @unique
  factorLabel     String
  leagueAvg       Float
  leagueSd        Float
  invert          Boolean  @default(false)
  isActive        Boolean  @default(false)
  methodologyIcon String?
  methodologyBold String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FeedSecret {
  id           String   @id @default(cuid())
  envVarName   String   @unique
  encrypted    String
  iv           String
  tag          String
  vercelSynced Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model FeedCache {
  id         Int      @id @default(autoincrement())
  feedSlug   String
  teamAbbrev String
  date       String
  value      Float
  rawData    Json?
  createdAt  DateTime @default(now())

  @@unique([feedSlug, teamAbbrev, date])
  @@index([feedSlug, date])
}
